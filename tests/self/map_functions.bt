test:has_key {
  @has_key_a[1] = 0;

  if (!has_key(@has_key_a, 1)) {
    return 1;
  }

  if (has_key(@has_key_a, 2)) {
    return 1;
  }

  $b = 1;
  if (!has_key(@has_key_a, $b)) {
    return 1;
  }

  @has_key_b["longerstr"] = 0;
  if (has_key(@has_key_b, "byeasdfasdfasdfasdfasdfasdf")) {
    return 1;
  }

  if (!has_key(@has_key_b, "longerstr")) {
    return 1;
  }

  @has_key_c[1, ("hello", ((int8)5))] = 0;
  if (!has_key(@has_key_c, (1, ("hello", 5)))) {
    return 1;
  }

  if (has_key(@has_key_c, (1, ("bye", ((uint16)5))))) {
    return 1;
  }

  @has_key_c[2, ("evenlongerstr", 10)] = 0;
  $a = (2, ("evenlongerstr", 10));
  if (!has_key(@has_key_c, $a)) {
    return 1;
  }
}
