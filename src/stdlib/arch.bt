// :variant uint8 usermode()
// Returns 1 if the current process is in user mode, 0 otherwise
//
// Currently only available on x86_64.
macro usermode() {
  $usermode = 0;
  if (valid(ctx.cs)) {
    $usermode = (ctx.cs & 0x3) != 0
  } else {
    fail("usermode is only supported on x86");
  }
  $usermode
}
